# backend/.env.example
# Copy to backend/.env for local development

# LLM provider: openai | groq | gemini
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Chroma DB path (optional - defaults to ../data/chroma_db)
CHROMA_PERSIST_DIRECTORY=../data/chroma_db

# Logging (optional)
# LOG_DIR=../logs