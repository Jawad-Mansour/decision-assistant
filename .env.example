# Copy to `.env` at the repo root. `docker compose` reads this file automatically.
# NEVER commit `.env`. `.env` is already covered by .gitignore.

# ---- LLM provider ---------------------------------------------------------
LLM_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (OpenAI-compatible API) — only needed when LLM_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Google Gemini — only needed when LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ---- Backend paths (defaults already wired in docker-compose) -------------
CHROMA_PERSIST_DIRECTORY=/app/data/chroma_db
LOG_DIR=/app/logs

# ---- Frontend host publishing --------------------------------------------
# The only port published to the host. Browser hits http://localhost:${FRONTEND_HOST_PORT}/
# and nginx proxies /query, /health, /predict, /answer to the backend internally.
FRONTEND_HOST_PORT=8080

# ---- Frontend <-> backend wiring inside the shared docker network --------
# Overridden per-platform (e.g. *.railway.internal on Railway).
BACKEND_HOST=backend
BACKEND_PORT=8000
